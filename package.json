{
  "name": "plan-maestro-produccion-appscript",
  "version": "2.41.0",
  "private": true,
  "description": "Plan maestro de producción con frontend en GitHub Pages y backend en Google Apps Script.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build-appscript.mjs",
    "check": "node scripts/check-project.mjs",
    "test": "node --test tests/*.test.mjs",
    "push": "npm run check && clasp push",
    "pull": "clasp pull",
    "open": "clasp open-script",
    "versions": "clasp versions",
    "deploy": "npm run check && clasp deploy",
    "build:pages": "node scripts/build-appscript.mjs",
    "preview:pages": "python -m http.server 4173 --directory site"
  }
}
